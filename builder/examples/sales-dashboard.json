{
  "id": "sales-analytics",
  "title": "Sales Analytics Dashboard",
  "description": "Track revenue, orders, and customer metrics across regions",
  "layout": {
    "type": "grid",
    "columns": 12,
    "rowHeight": 80,
    "gap": 8,
    "padding": 16
  },
  "theme": {
    "name": "default",
    "colors": {
      "primary": "#0ea5e9",
      "secondary": "#64748b",
      "background": "#f8fafc",
      "surface": "#ffffff",
      "text": "#0f172a",
      "border": "#e2e8f0"
    }
  },
  "variables": [
    {
      "id": "var-region",
      "name": "region",
      "label": "Region",
      "type": "select",
      "defaultValue": "all",
      "options": [
        { "label": "All Regions", "value": "all" },
        { "label": "North America", "value": "na" },
        { "label": "Europe", "value": "eu" },
        { "label": "Asia Pacific", "value": "apac" }
      ]
    },
    {
      "id": "var-period",
      "name": "period",
      "label": "Time Period",
      "type": "select",
      "defaultValue": "month",
      "options": [
        { "label": "This Month", "value": "month" },
        { "label": "This Quarter", "value": "quarter" },
        { "label": "This Year", "value": "year" }
      ]
    }
  ],
  "dataSources": [
    {
      "id": "sales-data",
      "type": "inline",
      "data": {
        "revenue": 1234567,
        "orders": 4521,
        "customers": 892,
        "avgOrderValue": 273,
        "revenueByMonth": [
          { "month": "Jan", "revenue": 95000 },
          { "month": "Feb", "revenue": 108000 },
          { "month": "Mar", "revenue": 121000 },
          { "month": "Apr", "revenue": 115000 },
          { "month": "May", "revenue": 132000 },
          { "month": "Jun", "revenue": 145000 }
        ],
        "salesByRegion": [
          { "region": "North America", "value": 45 },
          { "region": "Europe", "value": 30 },
          { "region": "Asia Pacific", "value": 20 },
          { "region": "Other", "value": 5 }
        ],
        "topProducts": [
          { "name": "Enterprise Plan", "revenue": 425000, "units": 85 },
          { "name": "Professional Plan", "revenue": 312000, "units": 520 },
          { "name": "Starter Plan", "revenue": 189000, "units": 1890 },
          { "name": "Add-ons", "revenue": 98000, "units": 2450 }
        ]
      }
    }
  ],
  "widgets": [
    {
      "id": "total-revenue",
      "type": "metric",
      "title": "Total Revenue",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "datasourceId": "sales-data",
      "config": {
        "valueField": "revenue",
        "format": "currency",
        "comparison": {
          "enabled": true,
          "value": 15.2,
          "label": "vs last period"
        }
      }
    },
    {
      "id": "total-orders",
      "type": "metric",
      "title": "Total Orders",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "datasourceId": "sales-data",
      "config": {
        "valueField": "orders",
        "format": "number",
        "comparison": {
          "enabled": true,
          "value": 8.7,
          "label": "vs last period"
        }
      }
    },
    {
      "id": "total-customers",
      "type": "metric",
      "title": "New Customers",
      "position": { "x": 6, "y": 0, "w": 3, "h": 2 },
      "datasourceId": "sales-data",
      "config": {
        "valueField": "customers",
        "format": "number",
        "comparison": {
          "enabled": true,
          "value": 12.3,
          "label": "vs last period"
        }
      }
    },
    {
      "id": "avg-order-value",
      "type": "metric",
      "title": "Avg. Order Value",
      "position": { "x": 9, "y": 0, "w": 3, "h": 2 },
      "datasourceId": "sales-data",
      "config": {
        "valueField": "avgOrderValue",
        "format": "currency",
        "comparison": {
          "enabled": true,
          "value": -2.1,
          "label": "vs last period"
        }
      }
    },
    {
      "id": "revenue-trend",
      "type": "chart",
      "title": "Revenue Trend",
      "position": { "x": 0, "y": 2, "w": 8, "h": 4 },
      "datasourceId": "sales-data",
      "config": {
        "geometry": "line",
        "xField": "month",
        "yField": "revenue",
        "colorScheme": ["#0ea5e9"],
        "showGrid": true,
        "smooth": true
      }
    },
    {
      "id": "sales-by-region",
      "type": "chart",
      "title": "Sales by Region",
      "position": { "x": 8, "y": 2, "w": 4, "h": 4 },
      "datasourceId": "sales-data",
      "config": {
        "geometry": "pie",
        "valueField": "value",
        "nameField": "region",
        "showLabels": true,
        "showLegend": true
      }
    },
    {
      "id": "top-products",
      "type": "table",
      "title": "Top Products",
      "position": { "x": 0, "y": 6, "w": 12, "h": 4 },
      "datasourceId": "sales-data",
      "config": {
        "columns": [
          { "field": "name", "header": "Product", "width": "40%" },
          { "field": "revenue", "header": "Revenue", "width": "30%", "format": "currency" },
          { "field": "units", "header": "Units Sold", "width": "30%", "format": "number" }
        ],
        "sortable": true,
        "pagination": {
          "enabled": true,
          "pageSize": 10
        }
      }
    }
  ]
}
